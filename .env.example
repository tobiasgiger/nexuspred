# nexuspred — environment variables (all optional)
# Copy to .env or export these before launching. .env is git-ignored.

# --- Tradovate access token (used first if set; takes precedence over settings) ---
# The access token is auto-renewed via renewaccesstoken (access -> check token),
# falling back to a username/password login if renewal fails.
TRADOVATE_ACCESS_TOKEN=
TRADOVATE_CHECK_TOKEN=

# --- Server ---
# HOST=0.0.0.0
# PORT=9000

# --- Auto-updater branch (default: main) ---
# NEXUSPRED_BRANCH=main
